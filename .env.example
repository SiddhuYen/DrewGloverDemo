# Serper.dev — used ONLY to locate roster / funding-announcement pages to scrape.
# Never used to mint edges from snippets. 2,500 free searches/month.
SERPER_API_KEY=

# OpenCorporates free-tier token (optional). Absent => provider no-ops.
OPENCORPORATES_API_TOKEN=

# SEC EDGAR requires a declared User-Agent with real contact info.
VCWI_EDGAR_USER_AGENT=VC WarmIntro Demo you@example.com

# Storage
VCWI_DB_URL=sqlite:///./vcwarmintro.db
VCWI_CACHE_DB=./vcwarmintro_cache.db

# Opt-in weak co-occurrence tier (the hybrid). OFF by default: the graph stays
# Rule-0 pure. Set to 1 to let enrichment mine tier-6 co_mention edges; even then
# they are only traversed by `connect --weak`.
VCWI_CO_MENTION_ENABLED=0
