# Derived enrichment work-queue artifacts (dumps of the scraped network —
# never commit to the public repo). Regenerated by scripts/enrich_unenriched.py.
data/*_unenriched.csv
data/*_unenriched_queue.json

# the bundled pre-built graph snapshot the desktop app ships. Committed GZIPPED
# (resources/graph.db.gz) because the enriched graph is >100MB raw, over
# GitHub's per-file cap; desktop/main.py + the devcontainer decompress it on
# first run. The raw .db stays ignored (*.db above); only the .gz is committed.
resources/graph.db
!resources/graph.db.gz
/build/work/
/build/*.toc
/dist/

# generated at CI build time from a repo secret — never committed, never
# present locally unless you've built the desktop app yourself
resources/claude_key.txt
resources/serper_key.txt
